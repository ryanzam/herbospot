generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  email         String   @unique
  image         String?
  role          Role     @default(user)
  emailVerified Boolean? @default(false) @map("email_verified")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // orders   Order[]
  // cart     Cart?
  sessions Session[]
  accounts Account[]

  @@map("users")
}

model Account {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  userId   String  @map("user_id") @db.ObjectId
  password String? @map("password_hash")

  // Better Auth specific fields
  accountId  String  @map("provider_account_id") // Maps your existing field
  providerId String  @map("provider") // Maps your existing field
  type       String?

  // NextAuth compatibility (Keep these if you have existing data)
  refresh_token String? @db.String
  access_token  String? @db.String
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String? @db.String
  session_state String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@map("accounts")
}

model Session {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  token     String    @unique @map("session_token")
  userId    String    @map("user_id") @db.ObjectId
  expires   DateTime?
  expiresAt DateTime? @map("expires_at")
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  identifier String?
  token      String    @unique
  expires    DateTime?

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum Role {
  user
  admin
}
